# ============================================================
# OVERSTOCKS ALLIANCE — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# Supabase (get these from your Supabase project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (get these from dashboard.stripe.com > Developers > API keys)
# Use TEST keys during development — they start with sk_test_
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
